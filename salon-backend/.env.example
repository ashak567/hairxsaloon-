# Hair X Studio — Backend Environment Variables
# Copy this to .env and fill in your values

# MongoDB connection string
MONGODB_URI=mongodb://localhost:27017/hair_x_studio

# JWT secret — change this to a long random string in production!
JWT_SECRET=hair_x_studio_super_secret_jwt_key_change_in_production

# Frontend URL for CORS
FRONTEND_URL=http://localhost:3000

# Port for the backend server
PORT=5000
